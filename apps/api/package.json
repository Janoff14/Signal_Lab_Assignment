{
  "name": "@signal-lab/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start:dev": "ts-node src/main.ts",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "build": "npm run prisma:generate && tsc -p tsconfig.json",
    "lint": "npm run prisma:generate && tsc --noEmit",
    "typecheck": "npm run prisma:generate && tsc --noEmit",
    "test": "npm --prefix ../../packages/contracts run build && npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/swagger": "^11.2.7",
    "@prisma/client": "^6.16.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "prisma": "^6.16.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.0"
  }
}
